    Program ceiling. S2 adds game-context throws after the volume block — feeds, relays, fielding throws at game effort. PT-directed volume. Completing this level clean with no symptoms is the final gate before full clearance.
  </div>

  <div class="session-card" id="card-L6S1">
    <div class="session-head" onclick="toggleSession('L6S1')">
      <div class="session-num">S1</div>
      <div class="session-info">
        <div class="session-title">120' — 1 × 25 throws</div>
        <div class="session-sub">Thu 4/9 &nbsp;·&nbsp; Rest + strength day follows</div>
      </div>
      <div class="session-tags"><span class="stag stag-dist">120 feet</span><span class="stag stag-vol">1 × 25</span></div>
      <div class="session-status" id="status-L6S1">Not started</div>
    </div>
    <div class="session-body" id="body-L6S1">
      <div class="sets-label">Sets — tap to mark complete</div>
      <div class="sets-grid" id="sets-L6S1">
        <div class="set-row" id="s-L6S1-1"><div class="set-check" onclick="toggleSet('s-L6S1-1','L6S1')"></div><div class="set-desc">Set 1 — 25 Throws<div class="set-detail">120 feet. 75–85% effort. Full arm arc — this distance demands it. Let hip drive carry the ball, don't add arm effort to compensate for distance.</div></div><div class="set-badge">120' · 25</div></div>
      </div>
      <div id="post-L6S1"></div>
      <div class="notes-grid">
        <div class="notes-box"><label>🩺 During-Session</label><textarea id="ta-L6S1-d" placeholder="Shoulder feel at program ceiling. Any new sensations? Deceleration quality? Rate 0–10."></textarea></div>
        <div class="notes-box"><label>🌙 Next-Day</label><textarea id="ta-L6S1-n" placeholder="Next-day soreness. Location and level. Posterior shoulder specifically."></textarea></div>
      </div>
    </div>
  </div>

  <div class="session-card" id="card-L6S2">
    <div class="session-head" onclick="toggleSession('L6S2')">
      <div class="session-num">S2</div>
      <div class="session-info">
        <div class="session-title">120' — 3 × 25 throws + game context</div>
        <div class="session-sub">Sat 4/11 &nbsp;·&nbsp; 3 min rest between sets &nbsp;·&nbsp; Final session</div>
      </div>
      <div class="session-tags"><span class="stag stag-dist">120 feet</span><span class="stag stag-vol">3 × 25</span><span class="stag stag-game">Game Throws</span></div>
      <div class="session-status" id="status-L6S2">Not started</div>
    </div>
    <div class="session-body" id="body-L6S2">
      <div class="sets-label">Sets — tap to mark complete</div>
      <div class="sets-grid" id="sets-L6S2">
        <div class="set-row" id="s-L6S2-1"><div class="set-check" onclick="toggleSet('s-L6S2-1','L6S2')"></div><div class="set-desc">Set 1 — 25 Throws<div class="set-detail">120 feet. Arm should be more settled than S1. Same mechanics cues throughout.</div></div><div class="set-badge">120' · 25</div></div>
        <div class="rest-row"><div class="rest-line"></div><span>3 min rest — shoulder check</span><div class="rest-line"></div></div>
        <div class="set-row" id="s-L6S2-2"><div class="set-check" onclick="toggleSet('s-L6S2-2','L6S2')"></div><div class="set-desc">Set 2 — 25 Throws<div class="set-detail">Maintain effort and mechanics. Any symptom increase set-to-set → stop per in-session criteria.</div></div><div class="set-badge">120' · 25</div></div>
        <div class="rest-row"><div class="rest-line"></div><span>3 min rest — full shoulder assessment before game throws</span><div class="rest-line"></div></div>
        <div class="set-row" id="s-L6S2-3"><div class="set-check" onclick="toggleSet('s-L6S2-3','L6S2')"></div><div class="set-desc">Set 3 — 25 Throws<div class="set-detail">Final volume set. Complete clean before moving into game-context block.</div></div><div class="set-badge">120' · 25</div></div>
        <div class="rest-row"><div class="rest-line"></div><span>5 min rest — full shoulder check before game throws</span><div class="rest-line"></div></div>
        <div class="set-row" id="s-L6S2-4"><div class="set-check" onclick="toggleSet('s-L6S2-4','L6S2')"></div><div class="set-desc">Game-Context Throws — PT Directed<div class="set-detail">Position-specific throws at game effort: feeds, relays, fielding throws. Volume and distance PT-directed based on same-day response. Same in-session criteria apply.</div></div><div class="set-badge">⚾ Game</div></div>
      </div>
      <div id="post-L6S2"></div>
      <div class="notes-grid">
        <div class="notes-box"><label>🩺 During-Session</label><textarea id="ta-L6S2-d" placeholder="120-foot full volume + game throws — final shoulder assessment. Rate 0–10."></textarea></div>
        <div class="notes-box"><label>🌙 Next-Day</label><textarea id="ta-L6S2-n" placeholder="Final recovery check. Any symptoms needing monitoring before clearance?"></textarea></div>
      </div>
      <div class="pt-review">
        <div class="pt-review-label">📝 PT Clinical Review — Program Completion</div>
        <textarea id="ta-L6S2-pt" placeholder="Final clearance assessment: 120ft volume tolerated, game-context throw response, symptom-free at full effort, mechanics quality throughout program, MD clearance status…"></textarea>
      </div>
    </div>
  </div>

  <div class="adv-box">
    <div class="adv-label">Program Complete — 6 Levels · 12 Sessions</div>
    <h3>Criteria for Return to Full Throwing Activity</h3>
    <p>✅&nbsp; All 12 sessions completed &nbsp;·&nbsp; ✅&nbsp; Game-context throws tolerated without mechanics breakdown &nbsp;·&nbsp; ✅&nbsp; Soreness ≤4/10 throughout, no next-day soreness &gt;24 hr &nbsp;·&nbsp; ✅&nbsp; PT and MD clearance<br><br><span class="hl">→ Return to full throwing: bullpen sessions, infield practice, live game throwing</span></p>
  </div>
</div>

</div><!-- wrap -->

<script>
var STORAGE_KEY = 'throwing_v1';
var toastTimer;

// ── INIT CRITERIA BLOCKS ──────────────────────
// Inject shared pre/in/mech criteria into each session-body, and post criteria into each post-div
window.addEventListener('DOMContentLoaded', function() {
  var critTpl = document.getElementById('tpl-criteria').innerHTML;
  var postTpl = document.getElementById('tpl-post').innerHTML;

  // Inject criteria at top of each level panel (after level-focus)
  document.querySelectorAll('.level-panel').forEach(function(panel) {
    var focus = panel.querySelector('.level-focus');
    var div = document.createElement('div');
    div.innerHTML = critTpl;
    focus.parentNode.insertBefore(div, focus.nextSibling);
  });

  // Inject post-session criteria into each post- div
  document.querySelectorAll('[id^="post-"]').forEach(function(el) {
    el.innerHTML = postTpl;
  });

  loadState();
});

// ── TAB SWITCHING ─────────────────────────────
function switchLevel(lv, silent) {
  document.querySelectorAll('.level-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('lv-active'); });
  document.getElementById('panel-' + lv).classList.add('active');
  document.querySelector('[data-lv="' + lv + '"]').classList.add('lv-active');
  if (!silent) saveState();
}

// ── SESSION ACCORDION ─────────────────────────
function toggleSession(key) {
  var b = document.getElementById('body-' + key);
  if (b) b.classList.toggle('open');
  saveState();
}

// ── CHECKBOX ──────────────────────────────────
function toggleSet(id, sessionKey) {
  var row = document.getElementById(id);
  var chk = row.querySelector('.set-check');
  var done = row.classList.toggle('set-done');
  chk.textContent = done ? '✓' : '';
  updateSessionStatus(sessionKey);
  updateAllProgress();
  saveState();
}

// ── SESSION STATUS ────────────────────────────
function updateSessionStatus(key) {
  var sets = document.querySelectorAll('#sets-' + key + ' .set-row');
  var done = Array.from(sets).filter(function(s) { return s.classList.contains('set-done'); });
  var statusEl = document.getElementById('status-' + key);
  var card = document.getElementById('card-' + key);
  if (!statusEl || !card) return;
  if (sets.length > 0 && done.length === sets.length) {
    statusEl.textContent = '✓ Complete';
    card.classList.add('completed');
  } else if (done.length > 0) {
    statusEl.textContent = done.length + '/' + sets.length + ' done';
    card.classList.remove('completed');
  } else {
    statusEl.textContent = 'Not started';
    card.classList.remove('completed');
  }
}

// ── PROGRESS BARS ─────────────────────────────
function updateLevelProgress(lv, s1key, s2key) {
  var keys = [s1key, s2key];
  var done = 0;
  keys.forEach(function(key) {
    var sets = document.querySelectorAll('#sets-' + key + ' .set-row');
    var doneCount = Array.from(sets).filter(function(s) { return s.classList.contains('set-done'); }).length;
    if (sets.length > 0 && doneCount === sets.length) done++;
  });
  var pct = Math.round(done / 2 * 100);
  document.getElementById('tb-' + lv).style.width = pct + '%';
  document.getElementById('tf-' + lv).style.width = pct + '%';
  document.getElementById('tc-' + lv).textContent = done + '/2';
}

function updateAllProgress() {
  updateLevelProgress(1, 'L1S1', 'L1S2');
  updateLevelProgress(2, 'L2S1', 'L2S2');
  updateLevelProgress(3, 'L3S1', 'L3S2');
  updateLevelProgress(4, 'L4S1', 'L4S2');
  updateLevelProgress(5, 'L5S1', 'L5S2');
  updateLevelProgress(6, 'L6S1', 'L6S2');
}

// ── STORAGE ───────────────────────────────────
function saveState() {
  var state = { checks: {}, notes: {}, open: [], lv: 1 };
  document.querySelectorAll('.set-row[id]').forEach(function(row) {
    state.checks[row.id] = row.classList.contains('set-done');
  });
  document.querySelectorAll('textarea[id]').forEach(function(ta) {
    state.notes[ta.id] = ta.value;
  });
  document.querySelectorAll('.session-body.open[id]').forEach(function(b) {
    state.open.push(b.id);
  });
  var activePanel = document.querySelector('.level-panel.active');
  if (activePanel) state.lv = parseInt(activePanel.id.replace('panel-', ''));
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
  flashToast();
}

function loadState() {
  var raw;
  try { raw = localStorage.getItem(STORAGE_KEY); } catch(e) {}
  if (!raw) return;
  var state;
  try { state = JSON.parse(raw); } catch(e) { return; }

  if (state.checks) {
    Object.keys(state.checks).forEach(function(id) {
      if (!state.checks[id]) return;
      var row = document.getElementById(id);
      if (!row) return;
      row.classList.add('set-done');
      var chk = row.querySelector('.set-check');
      if (chk) chk.textContent = '✓';
    });
  }
  if (state.notes) {
    Object.keys(state.notes).forEach(function(id) {
      var ta = document.getElementById(id);
      if (ta && state.notes[id]) ta.value = state.notes[id];
    });
  }
  if (state.open && state.open.length) {
    document.querySelectorAll('.session-body').forEach(function(b) { b.classList.remove('open'); });
    state.open.forEach(function(bid) {
      var b = document.getElementById(bid);
      if (b) b.classList.add('open');
    });
  }
  if (state.lv) switchLevel(state.lv, true);

  var allKeys = ['L1S1','L1S2','L2S1','L2S2','L3S1','L3S2','L4S1','L4S2','L5S1','L5S2','L6S1','L6S2'];
  allKeys.forEach(updateSessionStatus);
  updateAllProgress();
}

function flashToast() {
  var t = document.getElementById('toast');
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function() { t.classList.remove('show'); }, 1400);
}

var debounceTimer;
document.addEventListener('input', function(e) {
  if (e.target.tagName === 'TEXTAREA') {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(saveState, 500);
  }
});

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(function() {});
}
</script>
</body>
</html>
